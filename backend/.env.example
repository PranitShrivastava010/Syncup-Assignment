PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/syncup_db?schema=public"
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174

ACCESS_TOKEN_SECRET=replace_with_a_long_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_refresh_secret

# Free replacements for the assignment's paid services.
GROQ_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudinary is used as the free S3 alternative for resume uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_RESUME_FOLDER=syncup/resumes
